{
    "version": 2,
    "builds": [
        {
            "src": "frontend/index.html",
            "use": "@vercel/static"
        },
        {
            "src": "api/chat.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/api/chat",
            "dest": "api/chat.js"
        },
        {
            "src": "/",
            "dest": "frontend/index.html"
        }
    ],
    "env": {
        "API_BASE_URL": "@api_base_url"
    }
}
